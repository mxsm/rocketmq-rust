      "idempotentHint": true,
      "openWorldHint": true,
      "readOnlyHint": true,
      "title": "RocketMQ consumer lag diagnosis"
    },
    "description": "Diagnose consumer lag from read-only lag, topic route, and broker evidence.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "cluster": {
          "type": "string"
        },
