  "client_policy": {
    "package": "rocketmq-client-rust",
    "crate_names": ["rocketmq_client_rust", "rocketmq_client"],
    "target_manifest_allowlist": [
      {
        "caller": "rocketmq-admin-core",
        "target": "rocketmq-client-rust",
        "kind": "normal",
        "path": "rocketmq-tools/rocketmq-admin/rocketmq-admin-core/Cargo.toml",
        "alias": "rocketmq_client_rust"
      },
      {
        "caller": "rocketmq-proxy-cluster",
        "target": "rocketmq-client-rust",
        "kind": "normal",
        "path": "rocketmq-proxy-cluster/Cargo.toml",
        "alias": "rocketmq_client_rust"
      },
      {
        "caller": "rocketmq-example",
        "target": "rocketmq-client-rust",
        "kind": "dev",
        "path": "rocketmq-example/Cargo.toml",
        "alias": "rocketmq_client_rust"
      }
    ],
    "target_source_allowlist": [
      {
        "caller": "rocketmq-admin-core",
        "path_prefix": "rocketmq-tools/rocketmq-admin/rocketmq-admin-core/src/client_adapter/",
        "aliases": ["rocketmq_client_rust"]
      },
      {
        "caller": "rocketmq-proxy-cluster",
        "path_prefix": "rocketmq-proxy-cluster/src/",
        "aliases": ["rocketmq_client_rust"]
      },
      {
        "caller": "rocketmq-example",
        "path_prefix": "rocketmq-example/examples/",
        "aliases": ["rocketmq_client_rust"]
      }
    ]
  },
