{
  "schema_version": 1,
  "milestone": "M10-05",
  "default_max_regression_percent": 5.0,
  "minimum_samples": 5,
  "max_relative_mad_percent": 5.0,
  "max_sample_deviation_percent": 15.0,
  "required_environment_fields": [
    "hardware_id",
    "os",
    "kernel",
    "architecture",
    "cpu_model",
    "logical_cpus",
    "memory_bytes",
    "filesystem",
    "rustc",
    "cargo",
    "build_profile",
    "features",
    "measurement_method"
  ],
  "required_correctness_checks": [
    "sync_flush_crash_recovery",
    "derived_replay_no_holes",
    "bounded_overload",
    "no_raw_commitlog_fallback"
  ],
  "metric_sets": {
    "core": [
      {
        "id": "throughput_per_second",
        "unit": "operations/second",
        "direction": "higher",
        "comparison": "relative",
        "max_regression_percent": 5.0
      },
      {
        "id": "p99_latency_us",
        "unit": "microseconds",
        "direction": "lower",
        "comparison": "relative",
        "max_regression_percent": 5.0
      },
      {
        "id": "peak_rss_bytes",
        "unit": "bytes",
        "direction": "lower",
        "comparison": "relative",
        "max_regression_percent": 5.0
      },
      {
        "id": "allocations_per_operation",
        "unit": "allocations/operation",
        "direction": "lower",
        "comparison": "relative",
        "max_regression_percent": 5.0
      },
      {
        "id": "io_amplification_ratio",
        "unit": "bytes-read-written/payload-byte",
        "direction": "lower",
        "comparison": "relative",
        "max_regression_percent": 5.0
      }
    ]
  },
  "profiles": [
    {
      "id": "local-append",
      "description": "Local CommitLog append of 1 KiB messages at fixed producer concurrency.",
      "collection": {
        "driver": "target-hardware-sidecar",
        "status": "requires-target-hardware-run",
        "reference_commands": [
          "cargo bench -p rocketmq-store --bench commit_log_performance -- phase5/async_flush_multi_queue"
        ],
        "required_outputs": [
          "environment_metadata",
          "correctness_evidence",
          "raw_samples",
          "profile_report"
        ]
      },
      "metric_sets": ["core"],
      "metrics": [],
      "variants": [
        {
          "id": "producers-1",
          "parameters": {
            "message_size_bytes": 1024,
            "producers": 1,
            "flush_mode": "async",
            "tls_ratio": 0.0,
            "connection_activity": "steady"
          }
        },
        {
          "id": "producers-8",
          "parameters": {
            "message_size_bytes": 1024,
            "producers": 8,
            "flush_mode": "async",
            "tls_ratio": 0.0,
            "connection_activity": "steady"
          }
        },
        {
          "id": "producers-32",
          "parameters": {
            "message_size_bytes": 1024,
            "producers": 32,
            "flush_mode": "async",
            "tls_ratio": 0.0,
            "connection_activity": "steady"
          }
        }
      ],
      "hypotheses": [
        {
          "metric": "throughput_per_second",
          "operator": "min_improvement_percent",
          "value": 20.0,
          "gate": false
        },
        {
          "metric": "p99_latency_us",
          "operator": "min_improvement_percent",
          "value": 15.0,
          "gate": false
        }
      ]
    },
    {
